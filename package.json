{
  "name": "signalk-updater",
  "version": "0.1.0",
  "description": "Thin-shell SignalK plugin that surfaces the signalk-updater-server console in the admin UI",
  "main": "plugin/index.js",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dirkwa/signalk-updater.git"
  },
  "bugs": {
    "url": "https://github.com/dirkwa/signalk-updater/issues"
  },
  "homepage": "https://github.com/dirkwa/signalk-updater#readme",
  "engines": {
    "node": ">=22.5.0",
    "signalk": ">=2.24.0"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-category-utility",
    "updater",
    "container"
  ],
  "signalk-plugin-enabled-by-default": false,
  "signalk": {
    "displayName": "Updater",
    "appIcon": "icon.svg",
    "webapp": {
      "name": "Updater",
      "description": "Open the SignalK Updater Console"
    },
    "requires": [
      "signalk-container"
    ]
  },
  "files": [
    "plugin/**/*",
    "public/**/*",
    "icon.svg"
  ],
  "scripts": {
    "build:plugin": "rimraf plugin && tsc -p tsconfig.json",
    "build:webapp": "rimraf public && vite build",
    "build": "npm run build:plugin && npm run build:webapp",
    "build:all": "npm run lint && npm run build && npm test",
    "lint": "eslint src --max-warnings 0",
    "format": "prettier --write . && eslint src --fix",
    "ci-lint": "eslint src && prettier --check .",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@signalk/server-api": "^2.24.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.4.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.0",
    "vite": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
